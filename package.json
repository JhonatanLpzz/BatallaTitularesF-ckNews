{
  "name": "batalla-de-titulares",
  "version": "1.0.0",
  "private": true,
  "description": "Batalla de Titulares - Votación en vivo para F*ck News",
  "author": "Jhonatan Lopez Conde <Bogotá, Colombia>",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"api,web\" -c \"yellow,cyan\" \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "vite",
    "dev:server": "bun --watch server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "batalla-de-titulares": ".",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
