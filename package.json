{
  "name": "batalla-de-titulares",
  "version": "1.0.0",
  "private": true,
  "description": "Batalla de Titulares - Votación en vivo para F*ck News",
  "author": "Jhonatan Lopez Conde <Bogotá, Colombia>",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"api,web\" -c \"yellow,cyan\" \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "bunx --bun vite",
    "dev:server": "bun --watch server/index.ts",
    "build": "bunx --bun vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "sonner": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
